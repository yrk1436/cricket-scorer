# Copy to `.env.local` (never commit secrets).

# Backend (matches stored in your database project)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# PIN / unlock for editing completed scorecards
MATCH_UNLOCK_SECRET=

# Admin backdoor (/admin-scorecards) — long random string
ADMIN_SECRET=

# Optional: absolute links in dev/prod (e.g. http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=
